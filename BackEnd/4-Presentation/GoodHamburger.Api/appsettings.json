{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=GoodHamburgerDb;Username=admin;Password=password123;Include Error Detail=true"
  },
  "DatabaseSettings": {
    "CommandTimeout": 30,
    "MaxRetryCount": 3,
    "MaxRetryDelay": 5,
    "EnableSensitiveDataLogging": false,
    "EnableDetailedErrors": false,
    "MigrationsAssembly": "GoodHamburger.Database",
    "HealthCheck": {
      "Enabled": true,
      "Timeout": 5
    }
  }
}
