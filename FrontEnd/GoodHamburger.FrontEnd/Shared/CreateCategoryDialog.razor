@using GoodHamburger.FrontEnd.Clients.Categories
@using GoodHamburger.FrontEnd.Clients.MenuItems
@inject ICategoriesClient CategoriesClient
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Nova Categoria</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="@_success">
            <MudTextField T="string" Label="Nome" Required="true" @bind-Value="_command.Name" Variant="Variant.Outlined" Class="mb-4" />
            
            <MudTextField T="string" Label="Descrição" @bind-Value="_command.Description" Variant="Variant.Outlined" Class="mb-4" />
            
            <MudTextField T="string" Label="Slug" @bind-Value="_command.Slug" Variant="Variant.Outlined" Class="mb-4" />
            
            <MudSelect T="MenuCategoryType" Label="Tipo" Required="true" @bind-Value="_command.Type" Variant="Variant.Outlined" Class="mb-4">
                <MudSelectItem T="MenuCategoryType" Value="MenuCategoryType.Burger">Burger</MudSelectItem>
                <MudSelectItem T="MenuCategoryType" Value="MenuCategoryType.SideDish">Acompanhamento</MudSelectItem>
                <MudSelectItem T="MenuCategoryType" Value="MenuCategoryType.Drink">Bebida</MudSelectItem>
            </MudSelect>
            
            <MudTextField T="int" Label="Ordem de Exibição" Required="true" @bind-Value="_command.DisplayOrder" Variant="Variant.Outlined" Class="mb-4" />
            
            <MudTextField T="string" Label="URL da Imagem" @bind-Value="_command.ImageUrl" Variant="Variant.Outlined" Class="mb-4" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Disabled="@(!_success || _processing)">
            @if (_processing)
            {
                <MudProgressCircular Size="Size.Small" Class="ms-n1" Indeterminate="true" />
                <MudText Class="ms-2">Salvando...</MudText>
            }
            else
            {
                <MudText>Salvar</MudText>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;
    private MudForm _form = null!;
    private bool _success;
    private bool _processing;
    private CreateCategoryCommand _command = new();

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        _processing = true;
        try
        {
            var response = await CategoriesClient.CreateCategoryAsync(_command);
            if (response.Succeeded)
            {
                Snackbar.Add("Categoria criada com sucesso!", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add(string.Join(", ", response.Errors ?? new[] { "Erro ao criar categoria." }), Severity.Error);
            }
        }
        catch
        {
            Snackbar.Add("Erro ao criar categoria.", Severity.Error);
        }
        finally
        {
            _processing = false;
        }
    }
}
