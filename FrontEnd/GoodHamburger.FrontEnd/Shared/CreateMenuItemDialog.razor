@inject IGoodHamburgerClient ApiClient
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Novo Item do Menu</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="@_success">
            <MudTextField T="string" Label="Nome" Required="true" @bind-Value="_command.Name" Variant="Variant.Outlined" Class="mb-4" />
            
            <MudTextField T="string" Label="Descrição" @bind-Value="_command.Description" Variant="Variant.Outlined" Class="mb-4" />
            
            <MudTextField T="string" Label="SKU" Required="true" @bind-Value="_command.Sku" Variant="Variant.Outlined" Class="mb-4" />
            
            <MudTextField T="string" Label="Slug" @bind-Value="_command.Slug" Variant="Variant.Outlined" Class="mb-4" />
            
            <MudTextField T="double" Label="Preço" Required="true" @bind-Value="_command.Price" Variant="Variant.Outlined" Class="mb-4" />
            
            <MudSelect T="Guid" Label="Categoria" Required="true" @bind-Value="_command.CategoryId" Variant="Variant.Outlined" Class="mb-4">
                @if (_loadingCategories)
                {
                    <MudText Class="pa-2">Carregando...</MudText>
                }
                else
                {
                    @foreach (var category in _categories)
                    {
                        <MudSelectItem T="Guid" Value="@category.Id">@category.Name</MudSelectItem>
                    }
                }
            </MudSelect>
            
            <MudTextField T="int?" Label="Calorias" @bind-Value="_command.Calories" Variant="Variant.Outlined" Class="mb-4" />
            
            <MudTextField T="string" Label="URL da Imagem" @bind-Value="_command.ImageUrl" Variant="Variant.Outlined" Class="mb-4" />

            <MudText Typo="Typo.subtitle2" Class="mb-2">Ingredientes</MudText>
            @if (_loadingIngredients)
            {
                <MudText Class="pa-2">Carregando ingredientes...</MudText>
            }
            else
            {
                @foreach (var ingredient in _ingredients)
                {
                    <div class="d-flex align-center mb-2">
                        <MudCheckBox T="bool" @bind-Value="@ingredient.Selected" Label="@ingredient.Name" Class="flex-grow-1" />
                        <MudSwitch T="bool" @bind-Value="@ingredient.IsRemovable" Label="Removível" Disabled="@(!ingredient.Selected)" />
                    </div>
                }
            }
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Disabled="@(!_success || _processing)">
            @if (_processing)
            {
                <MudProgressCircular Size="Size.Small" Class="ms-n1" Indeterminate="true" />
                <MudText Class="ms-2">Salvando...</MudText>
            }
            else
            {
                <MudText>Salvar</MudText>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;
    private MudForm _form = null!;
    private bool _success;
    private bool _processing;
    private bool _loadingCategories = true;
    private bool _loadingIngredients = true;
    private List<CategoryDto> _categories = new();
    private List<IngredientSelection> _ingredients = new();
    private CreateMenuItemCommand _command = new();

    private class IngredientSelection
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public bool Selected { get; set; }
        public bool IsRemovable { get; set; } = true;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadCategories();
        await LoadIngredients();
    }

    private async Task LoadCategories()
    {
        try
        {
            var response = await ApiClient.GetActiveCategoriesAsync(1, 100);
            _categories = response.Items.ToList();
        }
        catch
        {
            Snackbar.Add("Erro ao carregar categorias.", Severity.Error);
        }
        finally
        {
            _loadingCategories = false;
        }
    }

    private async Task LoadIngredients()
    {
        try
        {
            var response = await ApiClient.GetAllIngredientsAsync(1, 100);
            _ingredients = response.Items.Select(i => new IngredientSelection
            {
                Id = i.Id,
                Name = i.Name,
                Selected = false,
                IsRemovable = true
            }).ToList();
        }
        catch
        {
            Snackbar.Add("Erro ao carregar ingredientes.", Severity.Error);
        }
        finally
        {
            _loadingIngredients = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        _processing = true;
        try
        {
            var response = await ApiClient.CreateMenuItemAsync(_command);
            if (response.Succeeded)
            {
                // Add selected ingredients to the menu item
                var selectedIngredients = _ingredients.Where(i => i.Selected).ToList();
                foreach (var ingredient in selectedIngredients)
                {
                    var addResponse = await ApiClient.AddIngredientToMenuItemAsync(response.Id, ingredient.Id, ingredient.IsRemovable);
                    if (!addResponse.Succeeded)
                    {
                        Snackbar.Add($"Erro ao adicionar ingrediente {ingredient.Name}: {string.Join(", ", addResponse.Errors ?? new[] { "Erro desconhecido" })}", Severity.Warning);
                    }
                }

                Snackbar.Add("Item criado com sucesso!", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add(string.Join(", ", response.Errors ?? new[] { "Erro ao criar item." }), Severity.Error);
            }
        }
        catch
        {
            Snackbar.Add("Erro ao criar item.", Severity.Error);
        }
        finally
        {
            _processing = false;
        }
    }
}
