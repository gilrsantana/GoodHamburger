@using GoodHamburger.FrontEnd.Clients.Ingredients
@inject IIngredientsClient ApiClient
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Novo Ingrediente</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="@_success">
            <MudTextField T="string" Label="Nome" Required="true" @bind-Value="_command.Name" Variant="Variant.Outlined" Class="mb-4" />
            
            <MudTextField T="string" Label="SKU" Required="true" @bind-Value="_command.Sku" Variant="Variant.Outlined" Class="mb-4" />
            
            <MudTextField T="double" Label="Preço de Custo de Referência" Required="true" @bind-Value="_command.ReferenceCostPrice" Variant="Variant.Outlined" Class="mb-4" />
            
            <MudTextField T="double" Label="Preço de Venda" Required="true" @bind-Value="_command.SalePrice" Variant="Variant.Outlined" Class="mb-4" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit" Disabled="@(!_success || _processing)">
            @if (_processing)
            {
                <MudProgressCircular Size="Size.Small" Class="ms-n1" Indeterminate="true" />
                <MudText Class="ms-2">Salvando...</MudText>
            }
            else
            {
                <MudText>Salvar</MudText>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;
    private MudForm _form = null!;
    private bool _success;
    private bool _processing;
    private CreateIngredientCommand _command = new();

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        _processing = true;
        try
        {
            var response = await ApiClient.CreateIngredientAsync(_command);
            if (response.Succeeded)
            {
                Snackbar.Add("Ingrediente criado com sucesso!", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add(string.Join(", ", response.Errors ?? new[] { "Erro ao criar ingrediente." }), Severity.Error);
            }
        }
        catch
        {
            Snackbar.Add("Erro ao criar ingrediente.", Severity.Error);
        }
        finally
        {
            _processing = false;
        }
    }
}
