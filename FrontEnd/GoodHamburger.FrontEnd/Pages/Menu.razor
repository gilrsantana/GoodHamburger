@page "/menu"
@using GoodHamburger.FrontEnd.Clients.Categories
@using GoodHamburger.FrontEnd.Clients.MenuItems
@using GoodHamburger.FrontEnd.Store.CartUseCase
@inject ICategoriesClient CategoriesClient
@inject IMenuItemsClient MenuItemsClient
@inject ISnackbar Snackbar
@inject IState<CartState> CartState
@inject IDispatcher Dispatcher

<PageTitle>Cardápio - Good Hamburger</PageTitle>

<MudText Typo="Typo.h4" Class="mb-6">Nosso Cardápio</MudText>

@if (_loading)
{
    <div class="d-flex justify-center align-center" style="height: 400px;">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
    </div>
}
else if (!_categories.Any())
{
    <MudAlert Severity="Severity.Info">Nenhuma categoria encontrada no momento.</MudAlert>
}
else
{
    <MudGrid>
        <MudItem xs="12" md="8">
            <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6">
                @foreach (var category in _categories.OrderBy(c => c.DisplayOrder))
                {
                    <MudTabPanel Text="@category.Name">
                        <MudGrid>
                            @foreach (var item in _menuItems.Where(i => i.CategoryId == category.Id))
                            {
                                <MudItem xs="12" sm="6" md="6" lg="4">
                                    <MudCard Elevation="4" Class="h-100 d-flex flex-column">
                                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                                        {
                                            <MudCardMedia Image="@item.ImageUrl" Height="150" />
                                        }
                                        else
                                        {
                                            <div class="d-flex align-center justify-center" style="height: 150px; background-color: var(--mud-palette-background-grey);">
                                                <MudIcon Icon="@Icons.Material.Filled.Fastfood" Size="Size.Large" Color="Color.Default" />
                                            </div>
                                        }
                                        <MudCardContent>
                                            <MudText Typo="Typo.h6">@item.Name</MudText>
                                            <MudText Typo="Typo.body2" Class="mb-2">@item.Description</MudText>
                                            <MudText Typo="Typo.h5" Color="Color.Primary">@item.Price?.ToString("C")</MudText>
                                        </MudCardContent>
                                        <MudSpacer />
                                        <MudCardActions>
                                            <MudButton Variant="Variant.Filled" 
                                                       Color="Color.Primary" 
                                                       FullWidth="true" 
                                                       StartIcon="@Icons.Material.Filled.AddShoppingCart"
                                                       OnClick="@(() => AddToCart(item))">
                                                Adicionar
                                            </MudButton>
                                        </MudCardActions>
                                    </MudCard>
                                </MudItem>
                            }
                        </MudGrid>
                    </MudTabPanel>
                }
            </MudTabs>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Elevation="4" Class="pa-4">
                <MudText Typo="Typo.h6" Class="mb-4">Seu Carrinho</MudText>
                @if (!CartState.Value.Items.Any())
                {
                    <MudAlert Severity="Severity.Info">Seu carrinho está vazio.</MudAlert>
                }
                else
                {
                    <MudList T="string">
                        @foreach (var cartItem in CartState.Value.Items)
                        {
                            <MudListItem>
                                <div class="d-flex justify-space-between align-center">
                                    <div>
                                        <MudText Typo="Typo.body1">@cartItem.MenuItem.Name</MudText>
                                        <MudText Typo="Typo.caption">@cartItem.MenuItem.CategoryName</MudText>
                                        @if (cartItem.Quantity > 1)
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Primary">Quantidade: @cartItem.Quantity</MudText>
                                        }
                                    </div>
                                    <div class="d-flex align-center">
                                        <MudText Typo="Typo.body2" Class="mr-4">@cartItem.TotalPrice.ToString("C")</MudText>
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => Dispatcher.Dispatch(new RemoveItemAction(cartItem.MenuItem.Id)))" />
                                    </div>
                                </div>
                            </MudListItem>
                        }
                    </MudList>

                    <MudDivider Class="my-4" />

                    @if (CartState.Value.PotentialDiscountPercentage > 0)
                    {
                        <div class="d-flex justify-space-between mb-2">
                            <MudText Color="Color.Success">Combo Discount (@(CartState.Value.PotentialDiscountPercentage.ToString("P0")))</MudText>
                            <MudText Color="Color.Success">-@CartState.Value.DiscountAmount.ToString("C")</MudText>
                        </div>
                    }

                    <div class="d-flex justify-space-between mb-4">
                        <MudText Typo="Typo.h6">Total:</MudText>
                        <MudText Typo="Typo.h6" Color="Color.Primary">@CartState.Value.FinalAmount.ToString("C")</MudText>
                    </div>

                    <MudButton Variant="Variant.Filled" Color="Color.Success" FullWidth="true" OnClick="@(() => Navigation.NavigateTo("checkout"))">Finalizar Pedido</MudButton>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    private bool _loading = true;
    private List<CategoryDto> _categories = new();
    private List<MenuItemDto> _menuItems = new();

    [Inject] private NavigationManager Navigation { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _loading = true;
            var categoriesResponse = await CategoriesClient.GetActiveCategoriesAsync(1, 100);
            var itemsResponse = await MenuItemsClient.GetAvailableMenuItemsAsync(1, 100);

            _categories = categoriesResponse.Items.ToList();
            _menuItems = itemsResponse.Items.ToList();
        }
        catch (Exception)
        {
            Snackbar.Add("Erro ao carregar o cardápio.", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void AddToCart(MenuItemDto item)
    {
        Dispatcher.Dispatch(new AddItemAction(item));
        Snackbar.Add($"{item.Name} adicionado!", Severity.Success);
    }
}
